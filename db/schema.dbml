// AgriBot Data Lake - Coherent Schema
// Version 5.0

TableGroup "Core Infrastructure" [color: #1E69FD] {
  users
  farms
  farm_ownerships
  fields
}

Enum user_role {
  admin
  farmer
  service_provider
}

Table users {
  id int [pk, increment]
  username varchar [not null, unique]
  password_hash varchar [not null]
  name varchar
  surname varchar
  role user_role [not null, default: 'farmer']
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  Note: 'Application users used for JWT authentication.'
}

Table farms {
  id int [pk, increment]
  name varchar [not null]
  location_center geometry // Postgis Point
  created_at timestamptz [not null, default: `now()`]
  Note: 'Farm registry. Ownership is defined in farm_ownerships.'
}

Table farm_ownerships {
  farm_id int [not null, ref: > farms.id]
  user_id int [not null, ref: > users.id]
  ownership_percentage decimal(5,2) [not null]

  indexes {
    (farm_id, user_id) [pk]
  }

  Note: 'Many-to-many ownership relation between users and farms.'
}

Table fields {
  id int [pk, increment]
  farm_id int [not null, ref: > farms.id]
  name varchar [not null]
  crop_name varchar
  boundary geometry //Postgis Polygon
  Note: 'Field / plot registry. boundary is a PostGIS Polygon in SRID 4326.'
}

TableGroup "Missions" {
  missions
  mission_types
}

Table mission_types{
  id varchar [pk]
  pilot_case varchar
  partner varhcar
  description varchar
}

enum mission_status{
  ongoing
  complete
  canceled
  aborted
}

Table missions {
  id varchar [pk]
  commander int [ref: > users.id]
  field int [ref: > fields.id]
  type varchar [ref: > mission_types.id]
  status mission_status
  start timestampz
  stop timestampz
  date timestampz
}

TableGroup "Pilot Case 1 (AUA): Weed Identification and spot spraying for wheat/corn" [color: #2D862B]{
pc1_weed
}

Table pc1_weed {
  id int [pk]
  inspection int [ref: > missions.id]
  name varchar
  image varchar
  confidence float
  weed_loc geometry // Postgis Point
  is_sprayed bool
  spray_time timestmapz
}



TableGroup "Pilot Case 2 (Ecorobotix): Robotic spraying of weeds in potato and volunteer potatoes" [color: #D95B16]{
  pc2_spraying_metadata
  pc2_spraying_mission

}

Table pc2_spraying_metadata
{
  id varchar [pk, ref: - missions.id]
  max_lat float
  min_lat float
  max_long float
  min_long float
  area_analyzed float
  average_density float
  crop_weed_correlation float
  weed_liquid_correlation float
}

Table pc2_spraying_mission 
{
  id varchar [pk, ref: > missions.id]
  properties jsonb
}

TableGroup "Pilot Case 3 (POLIBA): Robotic fertilization management for leafy vegetables in open field conditions" [color: #A934C1]{
pc3_inspections
}

Table pc3_inspections
{
  id varchar [pk, ref: > missions.id]
  location geometry // Postgis point
  biomass float(1.2)
  ndvi float(1.2)

}




