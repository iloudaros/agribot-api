TableGroup "Core Infrastructure" [color: #1E69FD] {
  users
  field_ownerships
  fields
}

Enum user_role {
  admin
  farmer
  service_provider
}

Table users {
  id int [pk, increment]
  email varchar [not null, unique]
  password_hash varchar [not null]
  name varchar
  role user_role [not null, default: 'farmer']
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  Note: 'Application users used for JWT authentication.'
}


Table field_ownerships {
  field_id int [not null, ref: > fields.id]
  user_id int [not null, ref: > users.id]
  ownership_percentage decimal(5,2) [not null]

  indexes {
    (field_id, user_id) [pk]
  }

  Note: 'Many-to-many ownership relation between users and farms.'
}

Table fields {
  id int [pk, increment]
  name varchar [not null]
  crop_name varchar
  boundary geometry [note:'Postgis Polygon']
  created_at timestamptz [not null, default: `now()`]
  Note: 'Field / plot registry. boundary is a PostGIS Polygon in SRID 4326.'
}

TableGroup "Missions" [color: #1E69FD]{
  missions
  mission_types
}

Table mission_types{
  id varchar [pk]
  pilot_case varchar
  partner varchar
  description varchar
}

enum mission_status{
  ongoing
  complete
  canceled
  aborted
}

Table missions {
  id int [pk, increment]
  commander_id int [ref: > users.id]
  field_id int [ref: > fields.id]
  mission_type varchar [ref: > mission_types.id]
  status mission_status
  start_time timestamptz
  end_time timestamptz
  mission_date timestamptz
}

TableGroup "Pilot Case 1 (AUA): Weed Identification and spot spraying for wheat/corn" [color: #2D862B]{
pc1_weed
pc1_missions
}

Table pc1_weed {
  id int
  inspection_id int [ref: > missions.id]
  name varchar
  image varchar
  confidence float
  weed_loc geometry [note:'Postgis Point']
  needs_verification bool
  verified bool
  is_sprayed bool
  spray_time timestamptz


    indexes {
    (id, inspection_id) [pk]
  }
}

enum pc1_mission_status{
  ongoing
  inspection_complete
  spraying_complete
  aborted
}

Table pc1_missions {
  mission_id int [pk, ref:> missions.id]
  status pc1_mission_status
}



TableGroup "Pilot Case 2 (Ecorobotix): Robotic spraying of weeds in potato and volunteer potatoes" [color: #D95B16]{
  pc2_missions

}


Table pc2_missions
{
  mission_id int [pk, ref: > missions.id]
  geojson_uri varchar
}

TableGroup "Pilot Case 3 (POLIBA): Robotic fertilization management for leafy vegetables in open field conditions" [color: #A934C1]{
pc3_inspections
}

Table pc3_inspections
{
  id int [pk, increment]
  mission_id int [not null, ref: > missions.id]
  timestamp_unix float
  location geometry [note:'Postgis Point']
  biomass float
  altitude_m float
  avg_dim_x_cm float
  avg_dim_y_cm float
  avg_dim_z_cm float
  avg_volume_cm3 float
  avg_fol_area_cm2 float
  avg_ndvi float
  avg_biomass float
  avg_fertilization float
}




TableGroup "Pilot Case 4 (POLIBA): Robotic technologies for crop monitoring and management in soilless tomato cultivation" [color: #050505] {
  pc4_pending
}

Table pc4_pending {
  pending int
}

TableGroup "Pilot Case 5 (KUL): Robotic harvesting in orchards" [color: #050505] {
  pc5_pending
}

Table pc5_pending {
  pending int
}


TableGroup "Pilot Case 6 (KUL): Robotic pruning and thinning with XR in orchards" [color: #050505] {
  pc6_pending
}

Table pc6_pending {
  pending int
}